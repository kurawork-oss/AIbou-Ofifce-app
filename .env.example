GEMINI_API_KEY=
# 使用モデル(省略時 gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Claude APIキー(従量課金)。Geminiが未設定/失敗時に使用。
ANTHROPIC_API_KEY=

# ===== Supabase 記憶保管庫(任意) =====
# supabase/schema.sql をSQL Editorで実行してから設定してください。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
